# Postgres connection string (Neon, Supabase, or any Postgres host).
# Use sslmode=verify-full (not "require") to get certificate verification
# explicitly rather than relying on pg's soon-to-change default aliasing.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=verify-full"

# Secret used to sign session cookies. Use a long random string in production.
JWT_SECRET="a-long-random-string"

# Free API key for the AI Assistant. Get one at https://console.groq.com/keys
GROQ_API_KEY="your-groq-api-key"

# API key for sending password-reset emails. Get one at https://resend.com
RESEND_API_KEY="your-resend-api-key"

# The "from" address used when sending email. onboarding@resend.dev works for
# testing before you verify your own sending domain.
RESEND_FROM_EMAIL="onboarding@resend.dev"
