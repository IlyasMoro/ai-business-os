# Postgres connection string (Neon, Supabase, or any Postgres host).
# Use sslmode=verify-full (not "require") to get certificate verification
# explicitly rather than relying on pg's soon-to-change default aliasing.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=verify-full"

# Secret used to sign session cookies. Use a long random string in production.
JWT_SECRET="a-long-random-string"

# Stable key Next.js uses to encrypt Server Action references. Required in
# production (especially with more than one server instance / rolling
# deploys) — without it Next.js generates a random key per build, and a
# client holding a reference from an old build/instance can resolve to the
# WRONG action once keys diverge. Generate with: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="a-stable-base64-encoded-32-byte-key"

# Free API key for the AI Assistant. Get one at https://console.groq.com/keys
GROQ_API_KEY="your-groq-api-key"

# API key for sending password-reset emails. Get one at https://resend.com
# Optional here — can instead be set at runtime on the Platform Settings page
# (/dashboard/platform-settings), which takes priority over these env vars.
RESEND_API_KEY="your-resend-api-key"

# The "from" address used when sending email. onboarding@resend.dev works for
# testing before you verify your own sending domain.
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Email of the one account that can see/edit Platform Settings (app-wide
# config like the Resend credential above) — deliberately not a database role,
# so it can't be granted by anything happening inside the app itself, only by
# whoever controls this environment variable.
PLATFORM_ADMIN_EMAIL="you@example.com"

# Base URL this app is reachable at (no trailing slash). Used to build the
# Google OAuth redirect URI. E.g. http://localhost:3000 in dev, or your
# Railway domain in production.
APP_BASE_URL="http://localhost:3000"

# Google OAuth Client ID/Secret for the Gmail integration (Integrations page).
# Create these at https://console.cloud.google.com — enable the Gmail API,
# then create an OAuth 2.0 Client ID (Web application) with an authorized
# redirect URI of {APP_BASE_URL}/api/integrations/google/callback.
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
