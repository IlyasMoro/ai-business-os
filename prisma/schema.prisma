generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Tenancy & Auth ----------

model Company {
  id        String   @id @default(cuid())
  name      String
  industry  String?
  createdAt DateTime @default(now())

  users              User[]
  customers          Customer[]
  products           Product[]
  suppliers          Supplier[]
  purchaseOrders     PurchaseOrder[]
  orders             Order[]
  invoices           Invoice[]
  transactions       Transaction[]
  employees          Employee[]
  payrollRuns        PayrollRun[]
  projects           Project[]
  tickets            Ticket[]
  chatMessages       AiChatMessage[]
  aiActions          AiAction[]
  auditLogs          AuditLog[]
  documents          Document[]
  automationSettings AutomationSettings?
  googleIntegration  GoogleIntegration?
  campaigns          Campaign[]
  calendarEvents     CalendarEvent[]
  subscription       Subscription?
}

enum UserRole {
  OWNER
  ADMIN
  EMPLOYEE
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String
  name                String
  role                UserRole  @default(OWNER)
  createdAt           DateTime  @default(now())
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  chatMessages        AiChatMessage[]
  requestedAiActions  AiAction[]           @relation("AiActionRequestedBy")
  decidedAiActions    AiAction[]           @relation("AiActionDecidedBy")
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]
  taskComments        TaskComment[]
  ticketMessages      TicketMessage[]

  @@index([companyId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RateLimitHit {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  metadata   String?
  createdAt  DateTime @default(now())

  companyId  String
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ---------- CRM ----------

enum CustomerStatus {
  LEAD
  ACTIVE
  INACTIVE
}

model Customer {
  id        String         @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  status    CustomerStatus @default(LEAD)
  notes     String?
  createdAt DateTime       @default(now())

  companyId  String
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  contacts Contact[]
  orders   Order[]
  invoices Invoice[]
  tickets  Ticket[]
  projects Project[]

  @@index([companyId])
  @@index([campaignId])
}

model Contact {
  id    String  @id @default(cuid())
  name  String
  email String?
  phone String?
  role  String?

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// ---------- Inventory ----------

model Product {
  id           String   @id @default(cuid())
  sku          String
  name         String
  description  String?
  cost         Float    @default(0)
  unitPrice    Float
  stockQty     Int      @default(0)
  reorderLevel Int      @default(5)
  createdAt    DateTime @default(now())

  companyId  String
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  orderItems         OrderItem[]
  invoiceLineItems   InvoiceLineItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([companyId, sku])
  @@index([companyId])
}

// ---------- Procurement ----------

model Supplier {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())

  companyId  String
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  purchaseOrders PurchaseOrder[]

  @@index([companyId])
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  status       PurchaseOrderStatus @default(DRAFT)
  totalAmount  Float               @default(0)
  createdAt    DateTime            @default(now())
  expectedDate DateTime?
  receivedAt   DateTime?

  companyId  String
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  items PurchaseOrderItem[]

  @@index([companyId])
  @@index([supplierId])
}

model PurchaseOrderItem {
  id       String @id @default(cuid())
  quantity Int
  unitCost Float

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
}

// ---------- Sales ----------

enum OrderStatus {
  PENDING
  CONFIRMED
  FULFILLED
  CANCELLED
}

model Order {
  id          String      @id @default(cuid())
  status      OrderStatus @default(PENDING)
  totalAmount Float       @default(0)
  createdAt   DateTime    @default(now())

  companyId  String
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  items   OrderItem[]
  invoice Invoice?

  @@index([companyId])
  @@index([customerId])
}

model OrderItem {
  id        String @id @default(cuid())
  quantity  Int
  unitPrice Float

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

// ---------- Invoicing ----------

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

model Invoice {
  id                 String        @id @default(cuid())
  invoiceNumber      String
  status             InvoiceStatus @default(DRAFT)
  issueDate          DateTime      @default(now())
  dueDate            DateTime
  totalAmount        Float         @default(0)
  createdAt          DateTime      @default(now())
  lastReminderSentAt DateTime?
  sentAt             DateTime?

  companyId  String
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  orderId String? @unique
  order   Order?  @relation(fields: [orderId], references: [id])

  lineItems    InvoiceLineItem[]
  transactions Transaction[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
}

model InvoiceLineItem {
  id          String @id @default(cuid())
  description String
  quantity    Int
  unitPrice   Float

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
}

// ---------- Accounting ----------

enum TransactionType {
  INCOME
  EXPENSE
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  category    String
  amount      Float
  description String?
  date        DateTime        @default(now())

  companyId  String
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([projectId])
}

// ---------- HR & Payroll ----------

enum EmployeeStatus {
  ACTIVE
  TERMINATED
}

model Employee {
  id         String         @id @default(cuid())
  name       String
  email      String?
  position   String?
  department String?
  salary     Float          @default(0)
  hireDate   DateTime       @default(now())
  status     EmployeeStatus @default(ACTIVE)

  companyId  String
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  payrollItems PayrollItem[]
  tasks        Task[]
  tickets      Ticket[]

  @@index([companyId])
}

enum PayrollRunStatus {
  DRAFT
  PROCESSED
  PAID
}

model PayrollRun {
  id          String           @id @default(cuid())
  periodStart DateTime
  periodEnd   DateTime
  status      PayrollRunStatus @default(DRAFT)
  totalAmount Float            @default(0)
  processedAt DateTime?

  companyId  String
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  items PayrollItem[]

  @@index([companyId])
}

model PayrollItem {
  id         String @id @default(cuid())
  grossPay   Float
  deductions Float  @default(0)
  netPay     Float

  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@index([payrollRunId])
}

// ---------- Project Management ----------

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  dueDate     DateTime?
  createdAt   DateTime      @default(now())

  companyId  String
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  tasks        Task[]
  transactions Transaction[]

  @@index([companyId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   Employee? @relation(fields: [assigneeId], references: [id])

  comments TaskComment[]

  @@index([projectId])
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// ---------- Customer Support ----------

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

model Ticket {
  id          String         @id @default(cuid())
  subject     String
  description String?
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  createdAt   DateTime       @default(now())

  companyId  String
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   Employee? @relation(fields: [assigneeId], references: [id])

  messages TicketMessage[]

  @@index([companyId])
}

enum TicketMessageAuthor {
  STAFF
  CUSTOMER
}

model TicketMessage {
  id         String              @id @default(cuid())
  content    String
  authorType TicketMessageAuthor
  createdAt  DateTime            @default(now())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id])

  @@index([ticketId])
}

// ---------- AI Assistant ----------

enum ChatRole {
  USER
  ASSISTANT
}

model AiChatMessage {
  id        String   @id @default(cuid())
  role      ChatRole
  content   String
  createdAt DateTime @default(now())

  companyId  String
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  aiActions AiAction[]

  @@index([companyId])
}

// ---------- AI Actions (proposals + audit log) ----------

enum AiActionType {
  CREATE_TASK
  UPDATE_TICKET_STATUS
  UPDATE_TICKET_PRIORITY
  UPDATE_CUSTOMER_STATUS
  CREATE_INVOICE
  SEND_OVERDUE_REMINDER
}

enum AiActionStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
  FAILED
}

model AiAction {
  id         String         @id @default(cuid())
  type       AiActionType
  status     AiActionStatus @default(PENDING)
  summary    String
  input      String
  result     String?
  error      String?
  createdAt  DateTime       @default(now())
  decidedAt  DateTime?
  executedAt DateTime?

  companyId  String
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  requestedByUserId String
  requestedBy       User   @relation("AiActionRequestedBy", fields: [requestedByUserId], references: [id])

  decidedByUserId String?
  decidedBy       User?   @relation("AiActionDecidedBy", fields: [decidedByUserId], references: [id])

  chatMessageId String?
  chatMessage   AiChatMessage? @relation(fields: [chatMessageId], references: [id])

  @@index([companyId])
  @@index([chatMessageId])
}

// ---------- Documents ----------

enum DocumentEntityType {
  CUSTOMER
  INVOICE
  TICKET
  PROJECT
  CAMPAIGN
  EMPLOYEE
}

model Document {
  id        String   @id @default(cuid())
  filename  String
  mimeType  String
  size      Int
  data      Bytes
  createdAt DateTime @default(now())

  companyId  String
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  entityType DocumentEntityType
  entityId   String

  @@index([companyId, entityType, entityId])
}

// ---------- Automation ----------

model AutomationSettings {
  id        String   @id @default(cuid())
  updatedAt DateTime @updatedAt

  overdueInvoiceReminders Boolean @default(false)
  lowStockReorder         Boolean @default(false)
  staleTicketEscalation   Boolean @default(false)
  staleLeadCleanup        Boolean @default(false)

  companyId  String  @unique
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ---------- Integrations ----------

model GoogleIntegration {
  id           String   @id @default(cuid())
  email        String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyId  String  @unique
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ---------- Automation locking ----------

// Singleton row (a fixed id, e.g. "automations") used as a lease lock so
// only one process runs a given background job at a time, safe under
// Prisma's connection pooling (unlike a Postgres advisory lock, which is
// tied to a specific connection the pool doesn't guarantee stays fixed
// across an acquire/release pair).
model RunLock {
  id          String    @id
  lockedUntil DateTime?
}

// ---------- Marketing ----------

enum CampaignChannel {
  EMAIL
  SOCIAL
  ADS
  EVENT
  REFERRAL
  OTHER
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

model Campaign {
  id        String          @id @default(cuid())
  name      String
  channel   CampaignChannel @default(OTHER)
  status    CampaignStatus  @default(DRAFT)
  budget    Float           @default(0)
  startDate DateTime?
  endDate   DateTime?
  notes     String?
  createdAt DateTime        @default(now())

  companyId  String
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  leads Customer[]

  @@index([companyId])
}

// ---------- Calendar ----------

enum CalendarEventType {
  MEETING
  REMINDER
  OTHER
}

model CalendarEvent {
  id          String            @id @default(cuid())
  title       String
  description String?
  type        CalendarEventType @default(MEETING)
  startAt     DateTime
  endAt       DateTime?
  createdAt   DateTime          @default(now())

  companyId  String
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, startAt])
}

// ---------- Billing ----------

// One flat-rate subscription per company. Single plan for now (see
// price_1TrKojRxRmfasatIyltWTQit in Stripe) — a Plan model can be added
// later if multiple tiers are introduced.
enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

model Subscription {
  id                   String             @id @default(cuid())
  status               SubscriptionStatus @default(TRIALING)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  companyId  String  @unique
  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ---------- Platform settings ----------

// Singleton row (fixed id "platform") for app-wide config that isn't tied to
// any one tenant company — e.g. the email-sending credential shared by every
// company's transactional email. Only settable by the platform operator
// (gated by PLATFORM_ADMIN_EMAIL, not by any company's OWNER role), since a
// regular tenant should never be able to see or overwrite the credential
// every other tenant's email depends on.
model PlatformSettings {
  id              String   @id
  resendApiKey    String?
  resendFromEmail String?
  updatedAt       DateTime @updatedAt
}
